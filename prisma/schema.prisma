// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String              @id @default(cuid())
  role              userType            @default(USER)
  firstName         String?
  lastName          String?
  email             String?             @unique
  password          String?
  emailVerified     DateTime?
  isVerified        Boolean             @default(false)
  accounts          Account[]
  sessions          Session[]
  class             Class[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  verificationToken VerificationToken[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Class {
  id         String    @id @default(uuid())
  name       String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime  @default(now())
  schoolYear String
  archived   Boolean   @default(false)
  students   Student[]
}

model Student {
  id          String       @id @default(uuid())
  name        String
  level       Int
  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     String
  assessments Assessment[]
  deletedAt   DateTime?
}

model Assessment {
  id        String         @id @default(uuid())
  studentId String
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  passageId String
  passage   Passage        @relation(fields: [passageId], references: [id])
  dateTaken DateTime       @default(now())
  type      AssessmentType

  oralReadingResult OralReadingResult?
  comprehension     ComprehensionTest?
  oralFluency       OralFluencySession?
}

model OralReadingResult {
  id                  String              @id @default(uuid())
  assessmentId        String              @unique
  assessment          Assessment          @relation(fields: [assessmentId], references: [id])
  fluencyLevel        LevelClassification
  comprehensionLevel  LevelClassification
  classificationLevel LevelClassification
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model OralFluencySession {
  id                  String               @id @default(cuid())
  assessmentId        String?              @unique
  audioUrl            String               @default("")
  transcript          String?
  wordsPerMinute      Float?
  accuracy            Float?
  totalWords          Int?
  totalMiscues        Int?
  duration            Float?
  oralFluencyScore    Float?
  classificationLevel LevelClassification?

  status    OralFluencyStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  deletedAt DateTime?

  assessment     Assessment?           @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  miscues        OralFluencyMiscue[]
  behaviors      OralFluencyBehavior[]
  wordTimestamps WordTimestamp[]
}

model WordTimestamp {
  id         String @id @default(cuid())
  sessionId  String
  word       String
  startTime  Float
  endTime    Float
  confidence Float?
  index      Int

  session OralFluencySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model OralFluencyMiscue {
  id              String     @id @default(cuid())
  sessionId       String
  miscueType      MiscueType
  expectedWord    String
  spokenWord      String?
  wordIndex       Int
  timestamp       Float?
  isSelfCorrected Boolean    @default(false)
  createdAt       DateTime   @default(now())

  session OralFluencySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model OralFluencyBehavior {
  id           String                  @id @default(cuid())
  sessionId    String
  behaviorType OralFluencyBehaviorType
  startIndex   Int?
  endIndex     Int?
  startTime    Float?
  endTime      Float?
  notes        String?
  createdAt    DateTime                @default(now())

  session OralFluencySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Passage {
  id          String       @id @default(uuid())
  title       String
  content     String
  language    String
  level       Int
  testType    testType
  assessments Assessment[]
  quiz        Quiz?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ComprehensionTest {
  id                  String                @id @default(uuid())
  assessmentId        String                @unique
  assessment          Assessment            @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  quizId              String
  quiz                Quiz                  @relation(fields: [quizId], references: [id])
  score               Int
  totalItems          Int
  classificationLevel LevelClassification
  answers             ComprehensionAnswer[]
}

model ComprehensionAnswer {
  id                  String            @id @default(uuid())
  comprehensionTestId String
  comprehensionTest   ComprehensionTest @relation(fields: [comprehensionTestId], references: [id], onDelete: Cascade)
  questionId          String
  question            Question          @relation(fields: [questionId], references: [id])
  answer              String
  isCorrect           Boolean?
  createdAt           DateTime          @default(now())
}

model Quiz {
  id                 String              @id @default(uuid())
  passageId          String              @unique
  passage            Passage             @relation(fields: [passageId], references: [id], onDelete: Cascade)
  questions          Question[]
  comprehensionTests ComprehensionTest[]
  totalScore         Int
  totalNumber        Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Question {
  id            String                @id @default(uuid())
  quizId        String
  quiz          Quiz                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText  String
  tags          Tags
  type          QuestionType
  options       Json?
  correctAnswer String?
  answers       ComprehensionAnswer[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

enum AssessmentType {
  ORAL_READING
  COMPREHENSION
  READING_FLUENCY
}

enum userType {
  USER
  ADMIN
}

enum testType {
  PRE_TEST
  POST_TEST
}

enum QuestionType {
  MULTIPLE_CHOICE
  ESSAY
}

enum Tags {
  Literal
  Inferential
  Critical
}

enum OralFluencyStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MiscueType {
  OMISSION
  MISPRONUNCIATION
  SUBSTITUTION
  REVERSAL
  TRANSPOSITION
  INSERTION
  SELF_CORRECTION
  REPETITION
}

enum OralFluencyBehaviorType {
  WORD_BY_WORD_READING
  MONOTONOUS_READING
  DISMISSAL_OF_PUNCTUATION
}

enum LevelClassification {
  INDEPENDENT
  INSTRUCTIONAL
  FRUSTRATION
}
