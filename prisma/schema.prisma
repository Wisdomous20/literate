// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id                 String              @id @default(cuid())
  role               userType            @default(USER)
  firstName          String?
  lastName           String?
  email              String?             @unique
  password           String?
  isVerified         Boolean             @default(false)
  isDisabled         Boolean             @default(false)
  accounts           Account[]
  sessions           Session[]
  classRoom          ClassRoom[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  verificationToken  VerificationToken[]
  subscription       Subscription?
  ownedOrganizations Organization[]       @relation("OrgOwner")
  orgMemberships     OrganizationMember[]

  @@map("users")
}

model Organization {
  id           String               @id @default(cuid())
  name         String
  ownerId      String
  owner        User                 @relation("OrgOwner", fields: [ownerId], references: [id])
  members      OrganizationMember[]
  subscription Subscription?        @relation("OrgSubscription")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([ownerId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String?            @unique
  user               User?              @relation(fields: [userId], references: [id])
  organizationId     String?            @unique
  organization       Organization?      @relation("OrgSubscription", fields: [organizationId], references: [id])
  planType           PlanType
  status             SubscriptionStatus @default(PENDING)
  maxMembers         Int                @default(1)
  xenditCustomerId   String?
  xenditPlanId       String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model ClassRoom {
  id         String    @id @default(cuid())
  name       String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime  @default(now())
  schoolYear String
  archived   Boolean   @default(false)
  students   Student[]

  @@index([userId])
  @@index([userId, schoolYear])
}

model Student {
  id          String       @id @default(cuid())
  name        String
  level       Int
  classRoom   ClassRoom    @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  classRoomId String
  assessments Assessment[]
  archived    Boolean      @default(false)

  @@index([classRoomId])
}

model Assessment {
  id        String         @id @default(cuid())
  studentId String
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  passageId String
  passage   Passage        @relation(fields: [passageId], references: [id])
  dateTaken DateTime       @default(now())
  type      AssessmentType

  oralReadingResult OralReadingResult?
  comprehension     ComprehensionTest?
  oralFluency       OralFluencySession?

  @@index([studentId])
  @@index([passageId])
  @@index([studentId, dateTaken(sort: Desc)])
}

model OralReadingResult {
  id                  String              @id @default(cuid())
  assessmentId        String              @unique
  assessment          Assessment          @relation(fields: [assessmentId], references: [id])
  fluencyLevel        LevelClassification
  comprehensionLevel  LevelClassification
  classificationLevel LevelClassification
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model OralFluencySession {
  id                  String               @id @default(cuid())
  assessmentId        String?              @unique
  audioUrl            String               @default("")
  transcript          String?              @db.Text
  wordsPerMinute      Float?
  accuracy            Float?
  totalWords          Int?
  totalMiscues        Int?
  duration            Float?
  oralFluencyScore    Float?
  classificationLevel LevelClassification?

  status    OralFluencyStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  deletedAt DateTime?

  assessment     Assessment?           @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  miscues        OralFluencyMiscue[]
  behaviors      OralFluencyBehavior[]
  wordTimestamps WordTimestamp[]
}

model WordTimestamp {
  id         String @id @default(cuid())
  sessionId  String
  word       String
  startTime  Float
  endTime    Float
  confidence Float?
  index      Int

  session OralFluencySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model OralFluencyMiscue {
  id              String     @id @default(cuid())
  sessionId       String
  miscueType      MiscueType
  expectedWord    String
  spokenWord      String?
  wordIndex       Int
  timestamp       Float?
  isSelfCorrected Boolean    @default(false)
  createdAt       DateTime   @default(now())

  session OralFluencySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model OralFluencyBehavior {
  id           String                  @id @default(cuid())
  sessionId    String
  behaviorType OralFluencyBehaviorType
  startIndex   Int?
  endIndex     Int?
  startTime    Float?
  endTime      Float?
  notes        String?
  createdAt    DateTime                @default(now())

  session OralFluencySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Passage {
  id          String       @id @default(cuid())
  title       String
  content     String
  language    String
  level       Int
  testType    testType
  assessments Assessment[]
  quiz        Quiz?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ComprehensionTest {
  id                  String                @id @default(cuid())
  assessmentId        String                @unique
  assessment          Assessment            @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  score               Int
  totalItems          Int
  classificationLevel LevelClassification
  answers             ComprehensionAnswer[]
}

model ComprehensionAnswer {
  id                  String            @id @default(cuid())
  comprehensionTestId String
  comprehensionTest   ComprehensionTest @relation(fields: [comprehensionTestId], references: [id], onDelete: Cascade)
  question            String
  tag                 Tags
  answer              String
  isCorrect           Boolean?
  createdAt           DateTime          @default(now())

  @@index([comprehensionTestId])
}

model Quiz {
  id          String     @id @default(cuid())
  passageId   String     @unique
  passage     Passage    @relation(fields: [passageId], references: [id], onDelete: Cascade)
  questions   Question[]
  totalScore  Int
  totalNumber Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Question {
  id            String       @id @default(uuid())
  quizId        String
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText  String
  tags          Tags
  type          QuestionType
  options       Json?
  correctAnswer String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([quizId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

enum AssessmentType {
  ORAL_READING
  COMPREHENSION
  READING_FLUENCY
}

enum userType {
  USER
  ADMIN
  ORG_ADMIN
}


enum testType {
  PRE_TEST
  POST_TEST
}

enum QuestionType {
  MULTIPLE_CHOICE
  ESSAY
}

enum Tags {
  Literal
  Inferential
  Critical
}

enum OralFluencyStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MiscueType {
  OMISSION
  MISPRONUNCIATION
  SUBSTITUTION
  REVERSAL
  TRANSPOSITION
  INSERTION
  SELF_CORRECTION
  REPETITION
}

enum OralFluencyBehaviorType {
  WORD_BY_WORD_READING
  MONOTONOUS_READING
  DISMISSAL_OF_PUNCTUATION
}

enum LevelClassification {
  INDEPENDENT
  INSTRUCTIONAL
  FRUSTRATION
}


enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
}

enum PlanType {
  SOLO
  KASALO
  PANALO
  PAMILYA
}